{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Drlinglong/remis-aventine/schemas/metric-pack.schema.json",
  "title": "Aventine Automatic Metric Pack",
  "description": "A bounded set of source, hypothesis, and optional reference strings for an external translation metric.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "suite", "cases"],
  "properties": {
    "schema_version": {"const": 1},
    "id": {"type": "string", "minLength": 1},
    "suite": {"type": "string", "minLength": 1},
    "description": {"type": "string"},
    "cases": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "source", "hypothesis"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "source": {"type": "string", "minLength": 1},
          "hypothesis": {"type": "string", "minLength": 1},
          "reference": {"type": "string", "minLength": 1},
          "metadata": {"type": "object"}
        }
      }
    }
  }
}
