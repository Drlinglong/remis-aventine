{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Drlinglong/remis-aventine/schemas/recipe-manifest.schema.json",
  "title": "Aventine Translation Recipe Manifest",
  "description": "A reproducible declaration of a translation pipeline, not merely a model name.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "id",
    "display_name",
    "source_language",
    "target_language",
    "provider",
    "model",
    "stages",
    "validator_policy"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]*$"
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string"
    },
    "source_language": {
      "type": "string",
      "minLength": 2
    },
    "target_language": {
      "type": "string",
      "minLength": 2
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "endpoint": {
          "type": "string",
          "format": "uri"
        },
        "settings": {
          "type": "object"
        }
      }
    },
    "model": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "revision": {
          "type": "string"
        },
        "settings": {
          "type": "object"
        }
      }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "implementation"],
        "properties": {
          "kind": {
            "enum": ["translate", "repair", "post_process"]
          },
          "implementation": {
            "type": "string",
            "minLength": 1
          },
          "prompt_revision": {
            "type": "string"
          },
          "settings": {
            "type": "object"
          }
        }
      }
    },
    "validator_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {
          "enum": ["veto", "disabled"]
        },
        "profile": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "mode": {
                "const": "veto"
              }
            }
          },
          "then": {
            "required": ["profile"]
          }
        }
      ]
    },
    "reference_access": {
      "enum": ["none", "judge_only", "recipe_and_judge"]
    },
    "metadata": {
      "type": "object"
    }
  }
}
