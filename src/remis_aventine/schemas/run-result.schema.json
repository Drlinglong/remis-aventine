{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Drlinglong/remis-aventine/schemas/run-result.schema.json",
  "title": "Aventine Run Result",
  "description": "A minimal, reproducible envelope for translation-recipe evaluation results.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "suite",
    "recipe",
    "started_at",
    "finished_at",
    "cases",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "suite": {
      "type": "string",
      "minLength": 1
    },
    "recipe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "sha256"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "finished_at": {
      "type": "string",
      "format": "date-time"
    },
    "environment": {
      "type": "object"
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["id", "execution_status", "hard_validation"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "execution_status": {
            "enum": ["completed", "execution_failure", "structured_output_failure"]
          },
          "hard_validation": {
            "type": "object",
            "additionalProperties": false,
            "required": ["enabled", "passed", "findings"],
            "properties": {
              "enabled": {
                "type": "boolean"
              },
              "passed": {
                "type": ["boolean", "null"]
              },
              "findings": {
                "type": "array",
                "items": {
                  "type": "object"
                }
              }
            }
          },
          "automatic_metrics": {
            "type": "object"
          },
          "judge": {
            "type": ["object", "null"]
          }
        }
      }
    },
    "summary": {
      "type": "object"
    }
  }
}
